# --- Automatische Loeschung (Aufbewahrung) -----------------------------------
RETENTION_DAYS=90
RETENTION_CRON=0 3 * * *
TRASH_RETENTION_DAYS=14

# --- Synchronisation auf lokale HDD -----------------------------------------
SYNC_ENABLED=false
SYNC_CRON=0 4 * * *
SYNC_HDD_PATH=./sync_target

# --- Speicher ----------------------------------------------------------------
STORAGE_WARN_PERCENT=90
MAX_UPLOAD_MB=5120

# =============================================================================
#  PERSISTENTE DATEN – Volume-Konfiguration
# =============================================================================
#
#  Modus A: Benannte Docker-Volumes (Standard, empfohlen)
#  -------------------------------------------------------
#  Die Standardwerte unterhalb erzeugen automatisch verwaltete Docker-Volumes.
#  Volumes bleiben auch nach "docker compose down" erhalten.
#  Anzeigen:   docker volume ls
#  Entfernen:  docker compose down -v  (LOESCHT ALLE DATEN!)
#
#  Modus B: Host-Verzeichnisse (Bind Mounts)
#  -----------------------------------------
#  Absolute Pfade (beginnend mit "/") werden als Bind Mounts behandelt.
#  Die Verzeichnisse muessen existieren und beschreibbar sein:
#    sudo mkdir -p /mnt/videovault/{media,thumbnails,trash,config}
#    sudo chown $USER /mnt/videovault/{media,thumbnails,trash,config}
#
#  Beispiel Bind Mounts (Kommentarzeichen entfernen und Pfade anpassen):
#  # MEDIA_VOLUME=/mnt/videovault/media
#  # THUMB_VOLUME=/mnt/videovault/thumbnails
#  # TRASH_VOLUME=/mnt/videovault/trash
#  # CONFIG_VOLUME=/mnt/videovault/config
#
#  Die Verzeichnisse werden beim Start AUTOMATISCH angelegt – kein
#  manuelles "mkdir" erforderlich.
#
#  Beide Modi koennen gemischt werden (z.B. Media auf NAS, Rest als Volume).
# =============================================================================

# Modus A (Standard): benannte Docker-Volumes
MEDIA_VOLUME=media_data
THUMB_VOLUME=thumb_data
TRASH_VOLUME=trash_data
CONFIG_VOLUME=config_data

# --- Blink-Verschluesselung --------------------------------------------------
# WICHTIG: Diesen Wert nach dem ersten Start NICHT mehr aendern!
# Aendern macht gespeicherte Blink-Zugangsdaten unlesbar → Konto muss neu verknuepft werden.
# Wird von install.sh automatisch generiert und in .env eingetragen.
